# ─────────────────────────────────────────────────────────────────────────────
# Probex — environment configuration
#
# Copy to `.env.local` and fill in values. Every variable below is read through
# src/config/env.ts (client-safe) or getServerEnv() (server-only). Leave values
# blank to keep running on mock data — the UI stays fully functional.
#
# NEXT_PUBLIC_* values are inlined into the client bundle. Never put secrets there.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend / API integration ───────────────────────────────────────────────
# SINGLE source of truth for the backend base URL — used by the shared Axios
# client (src/lib/api/client.ts) and the endpoint registry (src/lib/api/endpoints.ts).
# Must INCLUDE the /api prefix. Provided by the backend team; no trailing slash.
# Example: NEXT_PUBLIC_API_BASE_URL=http://136.171.119.6:8000/api
NEXT_PUBLIC_API_BASE_URL=

# Service mode: 'mock' (default, no backend needed) or 'live'.
NEXT_PUBLIC_API_MODE=mock

# Optional auxiliary base URL for a separate consensus API (lib/consensus).
NEXT_PUBLIC_CONSENSUS_API_URL=

# WebSocket endpoint for live market/consensus streaming (lib/realtime).
NEXT_PUBLIC_WS_URL=

# Enables the real-time stream layer (RealtimeProvider / liveStore).
NEXT_PUBLIC_ENABLE_REALTIME=

# ── App ──────────────────────────────────────────────────────────────────────
# Canonical app URL (Open Graph / metadata). e.g. https://app.probex.io
NEXT_PUBLIC_APP_URL=

# Verbose client debug logging (true/false). Drives the API client request log.
NEXT_PUBLIC_DEBUG=false

# ── Web3 / Polygon (wallet layer) ────────────────────────────────────────────
# Target chain: 137 = Polygon Mainnet, 80002 = Polygon Amoy testnet.
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract addresses (populated at deployment). 0x-prefixed.
NEXT_PUBLIC_CONTRACT_MARKET_137=
NEXT_PUBLIC_CONTRACT_VAULT_137=
NEXT_PUBLIC_CONTRACT_TOKEN_137=
NEXT_PUBLIC_CONTRACT_MARKET_80002=
NEXT_PUBLIC_CONTRACT_VAULT_80002=
NEXT_PUBLIC_CONTRACT_TOKEN_80002=
NEXT_PUBLIC_CONTRACT_USDC_80002=

# ── Server-only secrets (NEVER prefix with NEXT_PUBLIC_) ──────────────────────
# Read only via getServerEnv() in server components / API routes / middleware.
JWT_SECRET=
SESSION_SECRET=
DATABASE_URL=
INTERNAL_API_SECRET=
KYC_API_KEY=
